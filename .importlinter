[importlinter]
root_packages =
    backend
source_roots =
    src
include_external_packages = false
exclude_type_checking_imports = true

[importlinter:contract:backend_top_level_acyclic]
name = backend top-level siblings must be acyclic
type = acyclic_siblings
ancestors =
    backend
depth = 1

[importlinter:contract:agent_graph_must_not_read_video_summary_adapters]
name = agent_graph must not depend on video_summary adapters
type = forbidden
source_modules =
    backend.agent_graph
forbidden_modules =
    backend.video_summary.adapters

[importlinter:contract:agent_core_must_not_read_orchestration_or_product]
name = agent core must not depend on orchestration or product packages
type = forbidden
source_modules =
    backend.agent
forbidden_modules =
    backend.agent_graph
    backend.video_summary

[importlinter:contract:video_summary_adapters_must_not_read_agent_graph]
name = video_summary adapters must not depend on agent_graph
type = forbidden
source_modules =
    backend.video_summary.adapters
forbidden_modules =
    backend.agent_graph

[importlinter:contract:summary_generation_must_not_depend_on_api_or_adapters]
name = summary_generation must not depend on api or adapters
type = forbidden
source_modules =
    backend.video_summary.summary_generation
forbidden_modules =
    backend.api
    backend.video_summary.adapters
    backend.video_summary.composition
    backend.video_summary.configuration

[importlinter:contract:video_summary_layers]
name = video_summary package must keep inward dependency direction
type = layers
containers =
    backend.video_summary
layers =
    composition
    adapters
    configuration
    workspace
    summary_generation

[importlinter:contract:summary_generation_must_not_read_workspace]
name = summary_generation must not depend on workspace
type = forbidden
source_modules =
    backend.video_summary.summary_generation
forbidden_modules =
    backend.video_summary.workspace

[importlinter:contract:video_summary_agent_tools_must_not_read_technical_adapters]
name = video_summary agent tools must not depend on technical adapters
type = forbidden
source_modules =
    backend.video_summary.adapters.agent.tools
forbidden_modules =
    backend.video_summary.adapters.filesystem
    backend.video_summary.adapters.llm
    backend.video_summary.adapters.media
    backend.video_summary.adapters.progress
    backend.video_summary.adapters.rag
    backend.video_summary.composition
    backend.video_summary.configuration

[importlinter:contract:video_summary_agent_adapter_must_be_only_agent_bridge]
name = agent adapters are the only video_summary modules allowed to depend on backend.agent
type = forbidden
source_modules =
    backend.video_summary.summary_generation
    backend.video_summary.workspace
    backend.video_summary.adapters.filesystem
    backend.video_summary.adapters.llm
    backend.video_summary.adapters.media
    backend.video_summary.adapters.plugin
    backend.video_summary.adapters.progress
    backend.video_summary.adapters.rag
    backend.video_summary.composition
    backend.video_summary.configuration
forbidden_modules =
    backend.agent

[importlinter:contract:bilibili_must_not_read_video_summary_adapters]
name = bilibili must not depend on video_summary adapters directly
type = forbidden
source_modules =
    backend.bilibili
forbidden_modules =
    backend.video_summary.adapters
