# Copy this file to .env and fill in your local credentials.

# Required for summary generation.
OPENAI_API_KEY=

# Provider settings for the workspace "模型供应商" page.
OPENAI_PROVIDER=openai_compatible
OPENAI_BASE_URL=http://127.0.0.1:8317/v1
OPENAI_MODEL=gpt-5.4

# Optional HuggingFace mirror endpoint for model downloads in mainland China.
HF_ENDPOINT=https://hf-mirror.com
