# 复制本文件为 .env，然后填写本机使用的模型服务凭据。

# 摘要生成和 Agent 对话必填。不要把真实 API Key 提交到仓库。
OPENAI_API_KEY=

# 工作区“模型供应商”页面使用的模型服务配置。
OPENAI_PROVIDER=openai_compatible
OPENAI_BASE_URL=
OPENAI_MODEL=

# 可选：HuggingFace 模型下载镜像地址，国内网络环境可保留该默认值。
HF_ENDPOINT=https://hf-mirror.com
# 可选：B 站完整 Cookie 字符串（优先级最高）。playinfo 接口需要 SESSDATA 之外的多
# 个 cookie 联防（buvid3/4/fp、b_nut、bili_jct、_uuid、DedeUserID 等），只塞 SESSDATA
# 会被 WAF 412。在浏览器登录 B 站后从 DevTools 的 Network > 任意 bilibili.com 请求
# 的 Request Headers > cookie 字段复制整个值过来即可。
BILIBILI_COOKIE=

# 单 cookie 的兼容入口：仅在未设置 BILIBILI_COOKIE 时生效。
BILIBILI_SESSDATA=
